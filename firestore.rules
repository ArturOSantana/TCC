rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Verifica se o usuário é membro da viagem
    function isTripMember(tripId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/trips/$(tripId)) &&
        request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.members;
    }
    

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, delete: if isOwner(userId);
      // Permite update completo para o dono, ou apenas savedPosts para qualquer usuário autenticado
      allow update: if isOwner(userId) ||
                      (isAuthenticated() &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['savedPosts']));
    }
    
    match /trips/{tripId} {
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.members;
      allow read, update, delete: if isAuthenticated() && request.auth.uid in resource.data.members;
      
      // Subcoleção de journal com suporte a registros públicos
      match /journal/{entryId} {
        // Permitir leitura pública se o registro estiver marcado como público
        allow read: if resource.data.isPublic == true ||
                      (isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.members);
        // Permitir criação e atualização apenas para membros da viagem
        allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.members;
        allow update: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.members;
        allow delete: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.members;
      }
    }
    
    match /activities/{activityId} {
      allow create: if isAuthenticated() && isTripMember(request.resource.data.tripId);
      allow read, update, delete: if isAuthenticated() && isTripMember(resource.data.tripId);
    }
    
    match /expenses/{expenseId} {
      allow create: if isAuthenticated() && isTripMember(request.resource.data.tripId);
      allow read, update, delete: if isAuthenticated() && isTripMember(resource.data.tripId);
    }
    
    match /safety/{checkinId} {
      allow create: if isAuthenticated() && isTripMember(request.resource.data.tripId);
      allow read, update, delete: if isAuthenticated() && isTripMember(resource.data.tripId);
    }
    
    match /packing_items/{itemId} {
      allow create: if isAuthenticated() && isTripMember(request.resource.data.tripId);
      allow read, update, delete: if isAuthenticated() && isTripMember(resource.data.tripId);
    }
    
    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.receiverId == request.auth.uid;
    }


    match /services/{serviceId} {
      allow read: if isAuthenticated() || (resource != null && resource.data.isPublic == true);
      allow create: if isAuthenticated();
      // Permite update para curtidas e comentários (qualquer usuário autenticado)
      // Mas delete apenas para o dono
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && isOwner(resource.data.ownerId);
    }

    // Coleção journal (registros de viagem)
    match /journal/{entryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Permite update para reações (qualquer usuário autenticado)
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && isOwner(resource.data.userId);
    }

    // Avaliações de lugares
    match /place_ratings/{ratingId} {
      // Leitura: pública para avaliações públicas, privada para o dono
      allow read: if true; // Permite leitura para todos (simplificado)
      
      allow create: if isAuthenticated();
      
      allow update: if isAuthenticated() &&
                      (request.auth.uid == resource.data.userId ||
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'helpfulCount']));
      
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    match /destination_ratings/{ratingId} {
      allow read: if true;
      
      allow create: if isAuthenticated();
      
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}