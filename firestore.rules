rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isTripMember(tripId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/trips/$(tripId))
        && request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.members;
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
    
    match /journal/{entryId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }
    
    match /services/{serviceId} {
      allow read: if isAuthenticated() || (resource != null && resource.data.isPublic == true);
      allow create, update, delete: if isAuthenticated();
    }

    match /trips/{tripId} {
      allow read, write: if isAuthenticated();
    }
    
    match /activities/{activityId} {
      allow read, write: if isAuthenticated();
    }
    
    match /expenses/{expenseId} {
      allow read, write: if isAuthenticated();
    }
    
    match /safety_checkins/{checkinId} {
      allow read, write: if isAuthenticated();
    }
    
    match /photo_albums/{albumId} {
      allow read, write: if isAuthenticated();
    }
    
    match /packing_checklists/{checklistId} {
      allow read, write: if isAuthenticated();
    }

    match /packing_items/{itemId} {
      allow read, write: if isAuthenticated();
    }

    match /destination_ratings/{ratingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // --- NOVA REGRA PARA NOTIFICAÇÕES ---
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.receiverId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.receiverId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.receiverId == request.auth.uid;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}